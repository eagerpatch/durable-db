{
  "name": "durable-db",
  "version": "0.1.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/eagerpatch/durable-db.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.2.1",
  "bin": {
    "db": "./dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js"
    },
    "./migrations/snapshot": {
      "types": "./dist/migrations/snapshot.d.ts",
      "import": "./dist/migrations/snapshot.js"
    },
    "./migrations/generator": {
      "types": "./dist/migrations/generator.d.ts",
      "import": "./dist/migrations/generator.js"
    },
    "./vite": {
      "types": "./dist/vite/durableDb.d.ts",
      "import": "./dist/vite/durableDb.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./transport/protocol": {
      "types": "./dist/transport/protocol.d.ts",
      "import": "./dist/transport/protocol.js"
    },
    "./transport/websocket": {
      "types": "./dist/transport/websocket.d.ts",
      "import": "./dist/transport/websocket.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./virtual": {
      "types": "./virtual.d.ts"
    }
  },
  "files": [
    "dist",
    "virtual.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "changeset": "changeset"
  },
  "dependencies": {
    "@babel/generator": "^7.0.0",
    "@babel/parser": "^7.0.0",
    "@babel/traverse": "^7.0.0",
    "@babel/types": "^7.0.0",
    "@outerbase/browsable-durable-object": "^0.1.0",
    "arktype": "^2.1.28",
    "commander": "^13.1.0",
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.38.0",
    "esbuild": "^0.27.1",
    "kysely": "^0.27.0",
    "libsql": "^0.5.0",
    "magic-string": "^0.30.21"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@babel/generator": "^7.26.0",
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "@babel/types": "^7.26.0",
    "@changesets/cli": "^2.29.8",
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.27.1",
    "tsdown": "^0.17.2",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.0"
  }
}
